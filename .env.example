# Skopiuj ten plik do .env (nie commituj .env do repo!)
# .env jest ignorowany przez .gitignore.
#
# Wartości poniżej to PRZYKŁADY — wygeneruj własne!

# ─── API KEY ──────────────────────────────────────────────────────────────
# Dowolny długi losowy string. Używaj `openssl rand -hex 32` do wygenerowania.
# n8n wysyła go w nagłówku X-API-Key przy każdym żądaniu.
# Pusty = API publicznie dostępne (OK do testu lokalnego, NIE do deploya!).
API_KEY=zmien-to-na-cos-losowego-np-przez-openssl-rand-hex-32

# ─── CLAUDE API KEY ───────────────────────────────────────────────────────
# NIE jest używany przez API (Python API nie dzwoni do Claude).
# Ten klucz ustawiasz w n8n w Credentials → Anthropic, nie tutaj.
# ANTHROPIC_API_KEY=sk-ant-...
